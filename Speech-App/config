[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/Lilbarisx/EE471_Week6.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "text-to-speech"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/text-to-speech
[branch "speech-to-text"]
	vscode-merge-base = origin/main
